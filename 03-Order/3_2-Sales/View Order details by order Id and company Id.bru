meta {
  name: View Order details by order Id and company Id
  type: http
  seq: 4
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/orders/:orderId
  body: none
  auth: bearer
}

params:path {
  orderId: 123
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
