meta {
  name: Get sellable items by company
  type: http
  seq: 6
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/customers/:customer_id/items/sellable
  body: text
  auth: bearer
}

params:path {
  customer_id: 1
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
