meta {
  name: Get Payment Details By OrderId
  type: http
  seq: 8
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/orders/:orderId/payment-details
  body: text
  auth: bearer
}

params:path {
  orderId: 6
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
