meta {
  name: Get purchasable items by company
  type: http
  seq: 6
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/vendors/:vendor_id/items/purchasable
  body: text
  auth: bearer
}

params:path {
  vendor_id: 66
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
