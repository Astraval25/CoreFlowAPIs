meta {
  name: Get Invitation Code by Customer
  type: http
  seq: 6
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/invitations/customers/:customer_id/code
  body: none
  auth: bearer
}

params:path {
  customer_id: 143
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
