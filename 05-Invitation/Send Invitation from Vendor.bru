meta {
  name: Send Invitation from Vendor
  type: http
  seq: 2
}

post {
  url: {{astraval.com}}/api/companies/{{companyId}}/invitations/vendors/:vendor_id
  body: none
  auth: bearer
}

params:path {
  vendor_id: 1
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
