meta {
  name: Send Invitation from Customer
  type: http
  seq: 1
}

post {
  url: {{astraval.com}}/api/companies/{{companyId}}/invitations/customers/:customer_id
  body: none
  auth: bearer
}

params:path {
  customer_id: 143
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
