meta {
  name: Get Invitation Code by Vendor
  type: http
  seq: 7
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/invitations/vendors/:vendor_id/code
  body: none
  auth: bearer
}

params:path {
  vendor_id: 141
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
