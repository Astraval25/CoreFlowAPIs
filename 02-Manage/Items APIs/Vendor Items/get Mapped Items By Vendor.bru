meta {
  name: get Mapped Items By Vendor
  type: http
  seq: 5
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/vendors/:vendor_id/items/mapped
  body: json
  auth: bearer
}

params:path {
  vendor_id: 2
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
