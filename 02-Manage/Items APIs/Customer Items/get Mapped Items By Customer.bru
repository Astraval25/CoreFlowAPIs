meta {
  name: get Mapped Items By Customer
  type: http
  seq: 5
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/customers/:customer_id/items/mapped
  body: json
  auth: bearer
}

params:path {
  customer_id: 3
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
