meta {
  name: Create Customer Item
  type: http
  seq: 1
}

post {
  url: {{astraval.com}}/api/companies/{{companyId}}/customers/:customer_id/items
  body: json
  auth: bearer
}

params:path {
  customer_id: 3
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "itemId": 4,
    "salesPrice": 45.00,
    "salesDescription": "New Price"
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
