meta {
  name: Reset Portal User Password
  type: http
  seq: 9
}

patch {
  url: {{astraval.com}}/api/companies/{{companyId}}/modemp/employees/:employeeId/portal-user/reset-password
  body: json
  auth: bearer
}

params:path {
  employeeId: 1
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "password": "12345678900"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
