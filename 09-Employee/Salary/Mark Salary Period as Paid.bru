meta {
  name: Mark Salary Period as Paid
  type: http
  seq: 5
}

patch {
  url: {{astraval.com}}/api/companies/{{companyId}}/modemp/salary/periods/:salaryPeriodId/mark-paid
  body: json
  auth: bearer
}

params:path {
  salaryPeriodId: 1
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
