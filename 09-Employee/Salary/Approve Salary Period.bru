meta {
  name: Approve Salary Period
  type: http
  seq: 4
}

patch {
  url: {{astraval.com}}/api/companies/{{companyId}}/modemp/salary/periods/:salaryPeriodId/approve
  body: json
  auth: bearer
}

params:path {
  salaryPeriodId: 1
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
