meta {
  name: Deactivate Employee
  type: http
  seq: 7
}

patch {
  url: {{astraval.com}}/api/companies/{{companyId}}/modemp/employees/:employeeId/deactivate
  body: json
  auth: bearer
}

params:path {
  employeeId: 2
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "employeeName": "Jeeva S",
    "email": "jeeva.s@astraval.com",
    "phone": "0987654321",
    "salaryType": "WORK_BASED",
    "joinDate": "2026-04-01"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
