meta {
  name: Get Work Definitions Details
  type: http
  seq: 3
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/modemp/work-definitions/:workDefId
  body: json
  auth: bearer
}

params:path {
  workDefId: 1
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
