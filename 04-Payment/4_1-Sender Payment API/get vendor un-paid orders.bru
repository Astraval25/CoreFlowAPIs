meta {
  name: get vendor un-paid orders
  type: http
  seq: 4
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/vendor/:vendor_id/unpaid-orders
  body: none
  auth: bearer
}

params:path {
  vendor_id: 49
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
