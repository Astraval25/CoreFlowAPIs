meta {
  name: get customer un-paid orders
  type: http
  seq: 4
}

get {
  url: {{astraval.com}}/api/companies/{{companyId}}/customer/:customer_id/unpaid-orders
  body: none
  auth: bearer
}

params:path {
  customer_id: 118
}

auth:bearer {
  token: {{adminToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
